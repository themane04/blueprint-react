{
  "name": "blueprint-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" --log-level warn",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "i18n:extract": "i18next --config i18next-parser.config.cjs \"src/**/*.{ts,tsx}\" --silent",
    "i18n:check": "node scripts/i18n/check/index.cjs",
    "i18n": "npm run i18n:extract && npm run i18n:check",
    "i18n:new": "node scripts/i18n/new/index.cjs",
    "i18n:add-lang": "node scripts/i18n/add-lang/index.cjs",
    "barrel": "node scripts/barrel/index.cjs",
    "rtp": "npm run format && npm run i18n && npm run barrel && npm run lint"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.10.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "axios": "^1.13.6",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "framer-motion": "^12.23.12",
    "i18n-unused": "^0.19.0",
    "i18next": "^25.8.13",
    "i18next-parser": "^9.0.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.11.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "prettier": "^3.7.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.10"
  }
}
